<?xml version="1.0" encoding="UTF-8"?>
<wave_config>
   <wave_state>
   </wave_state>
   <db_ref_list>
      <db_ref path="my_tb_behav.wdb" id="1">
         <top_modules>
            <top_module name="glbl" />
            <top_module name="my_tb" />
         </top_modules>
      </db_ref>
   </db_ref_list>
   <zoom_setting>
      <ZoomStartTime time="0.000 ns"></ZoomStartTime>
      <ZoomEndTime time="104.601 ns"></ZoomEndTime>
      <Cursor1Time time="44.100 ns"></Cursor1Time>
   </zoom_setting>
   <column_width_setting>
      <NameColumnWidth column_width="340"></NameColumnWidth>
      <ValueColumnWidth column_width="150"></ValueColumnWidth>
   </column_width_setting>
   <WVObjectSize size="3" />
   <wvobject fp_name="/my_tb/s" type="array">
      <obj_property name="ElementShortName">s[2:0]</obj_property>
      <obj_property name="ObjectShortName">s[2:0]</obj_property>
   </wvobject>
   <wvobject fp_name="/my_tb/i" type="array">
      <obj_property name="ElementShortName">i[7:0]</obj_property>
      <obj_property name="ObjectShortName">i[7:0]</obj_property>
   </wvobject>
   <wvobject fp_name="/my_tb/y" type="logic">
      <obj_property name="ElementShortName">y</obj_property>
      <obj_property name="ObjectShortName">y</obj_property>
   </wvobject>
</wave_config>
